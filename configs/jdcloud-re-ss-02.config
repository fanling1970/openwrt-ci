#
# 自动生成的配置文件，请勿手动编辑（除非您知道自己在做什么）
# 适用机型：京东云 RE-CS-02 (AX6600) 3GB 内存版
#

# ============================================
# 第一部分：目标系统与设备型号
# ============================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
# 设备专属软件包：WiFi 固件、LED 控制
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="ipq-wifi-jdcloud_re-cs-02 kmod-ath11k-pci luci-app-athena-led luci-i18n-athena-led-zh-cn"

# ============================================
# 第二部分：内核与内存优化 (针对 3GB 大内存)
# ============================================
# NSS 驱动内存限制（IPQ60xx 平台固定为 512MB，不影响系统总内存）
CONFIG_KERNEL_IPQ_MEM_PROFILE=512
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_IPQ_MEM_PROFILE_512=y

# 启用 ZRAM 虚拟内存（用空间换时间，防止内存溢出）
CONFIG_KERNEL_ZRAM=y
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZORLE=y
CONFIG_ZRAM_SWAP=y

# 内核高级特性：大页内存、性能事件、控制组（Docker 必需）
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_HUGETLB=y
CONFIG_KERNEL_CGROUP_PERF=y
CONFIG_KERNEL_PERF_EVENTS=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_PIDS=y
CONFIG_KERNEL_CGROUP_CPUACCT=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_FREEZER=y
CONFIG_KERNEL_BLK_CGROUP=y
CONFIG_KERNEL_CGROUP_HUGETLB=y
CONFIG_KERNEL_VETH=y
CONFIG_KERNEL_BRIDGE=y
CONFIG_KERNEL_STP=y
CONFIG_KERNEL_DEVPTS_MULTIPLE_INSTANCES=y
CONFIG_KERNEL_OVERLAY_FS=y
CONFIG_KERNEL_USB_AUTOSUSPEND=y

# ============================================
# 第三部分：网络核心与 NSS 硬件加速
# ============================================
# 开启 NSS 硬件转发加速（跑满千兆网的关键）
CONFIG_NSS_DRV_IGS_ENABLE=y
CONFIG_NSS_DRV_L2TP_ENABLE=y
CONFIG_NSS_DRV_LAG_ENABLE=y
CONFIG_NSS_DRV_MAPT_ENABLE=y
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_VXLAN_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y

# 防火墙与 NAT 加速
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-ip6tables-nft=y

# ============================================
# 第四部分：Docker 容器支持
# ============================================
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y
CONFIG_PACKAGE_tini=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_cgroupfs-mount=y

# ============================================
# 第五部分：存储与 Samba4 文件共享
# ============================================
# Samba 服务器（支持 Mac 时间机器和 SMB 多通道）
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_samba4-server-multichannel=y
CONFIG_PACKAGE_samba4-server-fruit=y

# 文件系统支持（外接硬盘常用格式）
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-btrfs=y

# USB 3.0 驱动
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb3=y

# 磁盘挂载工具
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools=y

# ============================================
# 第六部分：LuCI Web 管理界面
# ============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-argon=y

# 核心系统应用
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y

# 功能型应用
CONFIG_PACKAGE_luci-app-dockerman=y       # Docker 管理
CONFIG_PACKAGE_luci-app-cupsd=y           # 打印服务
CONFIG_PACKAGE_luci-app-statistics=y      # 系统统计
CONFIG_PACKAGE_luci-app-nlbwmon=y         # 流量监控
CONFIG_PACKAGE_luci-app-sqm=y             # 智能队列管理（流控）
CONFIG_PACKAGE_luci-app-upnp=y            # UPnP 端口映射
CONFIG_PACKAGE_luci-app-netdata=y         # 实时性能监控
CONFIG_PACKAGE_luci-app-store=y           # iStore 商店
CONFIG_PACKAGE_luci-app-quickstart=y      # 快速向导

# 中文语言包
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-cupsd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-netdata-zh-cn=y

# ============================================
# 第七部分：系统工具与命令行
# ============================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y                     # 进程查看
CONFIG_PACKAGE_iperf3=y                   # 带宽测试
CONFIG_PACKAGE_lsof=y                     # 端口占用查看
CONFIG_PACKAGE_bash=y                     # 更好的 Shell
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_lm-sensors=y               # 硬件温度监控
CONFIG_PACKAGE_nano=y                     # 文本编辑器
CONFIG_PACKAGE_screen=y                   # 会话管理
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_zip=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_usbutils=y                 # USB 设备工具
CONFIG_PACKAGE_netdata=y                  # Netdata 核心程序
CONFIG_PACKAGE_nlbwmon=y                  # 流量监控核心

# ============================================
# 第八部分：明确禁用的项目 (保持纯净)
# ============================================
# 科学上网全家桶（全部移除，确保系统纯净稳定）
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-nikki is not set
# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_mihomo is not set
# CONFIG_PACKAGE_shadowsocks* is not set
# CONFIG_PACKAGE_trojan* is not set
# CONFIG_PACKAGE_hysteria is not set
# CONFIG_PACKAGE_tuic* is not set

# 冲突或冗余固件（防止 WiFi 驱动冲突）
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set
# CONFIG_PACKAGE_adguardhome is not set
# CONFIG_PACKAGE_mosdns is not set
