#
# =====================================================
# 目标系统与机型（Target System & Profile）
# =====================================================
#

# 使用 Qualcomm AX 平台
CONFIG_TARGET_qualcommax=y

# 使用 IPQ60XX 子平台（RE-CS-02 / AX1800 系列）
CONFIG_TARGET_qualcommax_ipq60xx=y

# 启用多机型 Profile（即使只编一个设备也建议开）
CONFIG_TARGET_MULTI_PROFILE=y

# ✅ 仅编译 JDCloud RE-CS-02
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# ❌ 关闭其他 IPQ60XX 设备，减少编译体积
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7500 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2 is not set

# 为该设备额外安装的包（雅典娜 LED 控制）
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"

#
# =====================================================
# 全局设置与内核参数（3G RAM 优化）
# =====================================================
#

# 每个设备独立 rootfs（多设备时必须）
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

# 使用 SquashFS（推荐，支持重置）
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# 不使用 initramfs
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# IPQ 平台内存配置（单位 MB）
CONFIG_IPQ_MEM_PROFILE_512=n
CONFIG_ATH11K_MEM_PROFILE_512M=n

# 内核内存 profile（1024 对 3G RAM 更稳）
CONFIG_KERNEL_IPQ_MEM_PROFILE=1024

# 启用 cgroup（Docker / 容器必需）
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_HUGETLB=y
CONFIG_KERNEL_CGROUP_PERF=y

# 透明大页（NSS + 大流量场景推荐）
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y

# ZRAM 压缩算法
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZORLE=y

#
# =====================================================
# 基础系统（Base System）
# =====================================================
#

# 使用自定义 BusyBox 配置
CONFIG_BUSYBOX_CUSTOM=y

# 启用 USB 设备查看（lsusb）
CONFIG_BUSYBOX_CONFIG_LSUSB=y

# 启用 IPv6 支持
CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6=y

#
# =====================================================
# NSS 硬件加速（Qualcomm 核心优势）
# =====================================================
#

# NSS 12.2 固件（6.12 推荐）
CONFIG_NSS_FIRMWARE_VERSION_12_2=y

# 各类型 NSS 功能模块
CONFIG_NSS_DRV_IGS_ENABLE=y              # IGS（组播加速）
CONFIG_NSS_DRV_L2TP_ENABLE=y             # L2TP 加速
CONFIG_NSS_DRV_LAG_ENABLE=y              # 链路聚合
CONFIG_NSS_DRV_MAPT_ENABLE=y             # MAP-T 转换
CONFIG_NSS_DRV_PPTP_ENABLE=y             # PPTP 加速
CONFIG_NSS_DRV_PVXLAN_ENABLE=y           # VXLAN 加速
CONFIG_NSS_DRV_SHAPER_ENABLE=y           # 限速
CONFIG_NSS_DRV_VXLAN_ENABLE=y            # VXLAN 通用

# NSS 内核模块
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=y

# 调度器（配合 NSS 使用）
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y

#
# =====================================================
# LuCI Web 管理界面
# =====================================================
#

CONFIG_LUCI_LANG_zh_Hans=y               # 简体中文
CONFIG_PACKAGE_luci=y                    # LuCI 主框架
CONFIG_PACKAGE_luci-light=y              # 轻量 LuCI
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-lua-runtime=y

# 常用管理模块
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y

# 网络协议支持
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

# Argon 主题（好看）
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

#
# =====================================================
# Docker 支持（✅ 预装 + 开机可用）
# =====================================================
#

# Docker 核心
CONFIG_PACKAGE_docker=y                  # Docker CLI
CONFIG_PACKAGE_dockerd=y                 # Docker Daemon
CONFIG_PACKAGE_containerd=y             # containerd
CONFIG_PACKAGE_runc=y                   # runc
CONFIG_PACKAGE_docker-compose=y          # docker-compose

# Docker 所需 cgroup / 内核支持
CONFIG_DOCKER_CGROUP_OPTIONS=y

# LuCI Docker 管理页面
CONFIG_PACKAGE_luci-app-dockerman=y

#
# =====================================================
# 系统统计（collectd）
# =====================================================
#

CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-rrdtool=y
CONFIG_PACKAGE_collectd-mod-thermal=y

#
# =====================================================
# 流量监控 / UPnP
# =====================================================
#

CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y

CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_miniupnpd-nftables=y

#
# =====================================================
# iStore 商店 & 快速向导
# =====================================================
#

CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-quickstart=y

#
# =====================================================
# 存储 / USB / Samba
# =====================================================
#

CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y

CONFIG_SAMBA4_SERVER_AVAHI=y
CONFIG_SAMBA4_SERVER_WSDD2=y

CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb3=y

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_zram-swap=y               # 启用 zram 交换

#
# =====================================================
# 实用工具
# =====================================================
#

CONFIG_PACKAGE_luci-app-ttyd=y           # Web 终端
CONFIG_PACKAGE_luci-app-wol=y            # 网络唤醒
CONFIG_PACKAGE_iperf3=y                  # 带宽测试

#
# =====================================================
# 防火墙（nftables + NAT 加速）
# =====================================================
#

CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_iptables-mod-fullconenat=y

#
# =====================================================
# ❌ 已移除：代理 / VPN / 科学上网
# =====================================================
#

# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_hysteria is not set
# CONFIG_PACKAGE_chinadns-ng is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-openclash is not set

#
# =====================================================
# ❌ 已移除：打印服务
# =====================================================
#

# CONFIG_PACKAGE_luci-app-cupsd is not set
# CONFIG_PACKAGE_cups is not set
# CONFIG_PACKAGE_cups-filters is not set
# CONFIG_PACKAGE_kmod-usb-printer is not set

#
# =====================================================
# ❌ 已移除：非必要应用
# =====================================================
#

# CONFIG_PACKAGE_luci-app-netspeedtest is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set
# CONFIG_PACKAGE_zerotier is not set
# CONFIG_PACKAGE_luci-app-netdata is not set
# CONFIG_PACKAGE_netdata is not set
# CONFIG_PACKAGE_luci-app-sqm is not set
# CONFIG_PACKAGE_sqm-scripts is not set

#
# =====================================================
# 默认设置（中文环境 / 包管理器）
# =====================================================
#

CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
